# ── Required ──────────────────────────────────────────────
OPENAI_API_KEY=your_openai_key_here
QDRANT_URL=https://your-cluster.qdrant.io
QDRANT_API_KEY=your_qdrant_api_key_here
COHERE_API_KEY=your_cohere_api_key_here

# ── Models ────────────────────────────────────────────────
EMBEDDING_MODEL=text-embedding-3-small
QUERY_MODEL=gpt-4o-mini
GENERATION_MODEL=gpt-4o-mini
RERANK_MODEL=rerank-english-v3.0

# ── Qdrant collection ─────────────────────────────────────
COLLECTION_NAME=career_intelligence

# ── Retrieval settings ────────────────────────────────────
TOP_K_RETRIEVE=20
TOP_K_RERANK=5
HYDE_ENABLED=true
BM25_ENABLED=true

# ── Optional: use in-memory Qdrant for local testing ──────
# Set to "memory" to skip Qdrant Cloud entirely
QDRANT_MODE=cloud
# QDRANT_MODE=memory